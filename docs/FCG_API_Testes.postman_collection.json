{
  "info": {
    "_postman_id": "4f2e8ab6-4e2f-4bd3-8ca6-87f7ff4f4b81",
    "name": "FCG - Fluxo Completo de Testes",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Colecao para validar health, autenticacao, jogos, promocoes, usuarios admin e biblioteca."
  },
  "variable": [
    { "key": "baseUrl", "value": "https://localhost:5001" },
    { "key": "adminEmail", "value": "admin@fcg.local" },
    { "key": "adminPassword", "value": "Admin@123x" },
    { "key": "userEmail", "value": "usuario.teste@fcg.local" },
    { "key": "userPassword", "value": "Teste@123" },
    { "key": "adminToken", "value": "" },
    { "key": "userToken", "value": "" },
    { "key": "gameId", "value": "" },
    { "key": "userId", "value": "" }
  ],
  "item": [
    {
      "name": "01 - Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "02 - Auth",
      "item": [
        {
          "name": "Registrar usuario comum",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Usuario Teste\",\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Login admin (salva adminToken)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "var data = pm.response.json();",
                  "if (data && data.token) {",
                  "  pm.collectionVariables.set('adminToken', data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Login usuario (salva userToken/userId)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "var data = pm.response.json();",
                  "if (data && data.token) {",
                  "  pm.collectionVariables.set('userToken', data.token);",
                  "}",
                  "if (data && data.userId) {",
                  "  pm.collectionVariables.set('userId', data.userId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        }
      ]
    },
    {
      "name": "03 - Jogos",
      "item": [
        {
          "name": "Criar jogo (admin, salva gameId)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "var data = pm.response.json();",
                  "if (data && data.id) {",
                  "  pm.collectionVariables.set('gameId', data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Jogo de Teste\",\n  \"genero\": \"Educacao\",\n  \"preco\": 49.9\n}"
            },
            "url": "{{baseUrl}}/api/games"
          }
        },
        {
          "name": "Listar jogos",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/games"
          }
        },
        {
          "name": "Criar jogo com usuario comum (esperado 403)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Nao Deve Criar\",\n  \"genero\": \"Teste\",\n  \"preco\": 1\n}"
            },
            "url": "{{baseUrl}}/api/games"
          }
        }
      ]
    },
    {
      "name": "04 - Promocoes",
      "item": [
        {
          "name": "Criar promocao (admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Promo de Teste\",\n  \"descricao\": \"Desconto de validacao\",\n  \"percentualDesconto\": 10,\n  \"dataPromoInicio\": \"2026-01-01T00:00:00Z\",\n  \"dataPromoFim\": \"2027-01-01T00:00:00Z\",\n  \"gameId\": \"{{gameId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/admin/promocoes"
          }
        },
        {
          "name": "Listar promocoes",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/promocoes"
          }
        }
      ]
    },
    {
      "name": "05 - Usuario / Biblioteca",
      "item": [
        {
          "name": "Meu perfil",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "url": "{{baseUrl}}/api/users/me"
          }
        },
        {
          "name": "Adicionar jogo na biblioteca",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "url": "{{baseUrl}}/api/users/me/biblioteca/games/{{gameId}}"
          }
        },
        {
          "name": "Listar biblioteca",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "url": "{{baseUrl}}/api/users/me/biblioteca"
          }
        }
      ]
    },
    {
      "name": "06 - Admin Usuarios",
      "item": [
        {
          "name": "Listar usuarios (admin)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/api/admin/users"
          }
        },
        {
          "name": "Alterar perfil do usuario para Administrador (admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"Administrador\"\n}"
            },
            "url": "{{baseUrl}}/api/admin/users/{{userId}}/role"
          }
        }
      ]
    }
  ]
}
