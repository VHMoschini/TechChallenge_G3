{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "NewRelic": {
    "Enabled": false,
    "ApplicationName": "FCG-Dev",
    "LogsEndpointUrl": "https://log-api.newrelic.com/log/v1",
    "LicenseKey": "",
    "InsertKey": ""
  },
  "Seed": {
    "AdminEmail": "admin@fcg.local",
    "AdminPassword": "Admin@123x",
    "AdminName": "Administrador"
  }
}
